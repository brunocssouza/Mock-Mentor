generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model feedback {
  id                     Int      @id @default(autoincrement())
  session_id             Int      @unique(map: "uq_feedback_session")
  technical_rating       Int      @db.UnsignedTinyInt
  behavioral_rating      Int      @db.UnsignedTinyInt
  improvement_suggestion String?  @db.Text
  created_at             DateTime @default(now()) @db.Timestamp(0)
  session                session  @relation(fields: [session_id], references: [id], onDelete: Cascade, map: "fk_feedback_session")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model mentor {
  id                      Int                 @id @default(autoincrement())
  user_id                 Int                 @unique(map: "uq_mentor_user")
  title                   String              @db.VarChar(120)
  company                 String?             @db.VarChar(120)
  description             String              @db.Text
  professional_experience String?             @db.Text
  price_per_session       Decimal             @default(0.00) @db.Decimal(10, 2)
  rating                  Decimal             @default(0.0) @db.Decimal(2, 1)
  total_reviews           Int                 @default(0) @db.UnsignedInt
  presentation_video_url  String?             @db.VarChar(512)
  approved                Boolean             @default(false)
  availability            availability[]
  user                    user                @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_mentor_user")
  mentor_language         mentor_language[]
  mentor_review           mentor_review[]
  mentor_technology       mentor_technology[]
  session                 session[]
}

model activity_log {
  id          String   @id @db.VarChar(36)
  user_id     Int
  action      String   @db.VarChar(100)
  entity_type String?  @db.VarChar(50)
  entity_id   String?  @db.VarChar(36)
  metadata    Json?
  ip_address  String?  @db.VarChar(45)
  created_at  DateTime @default(now()) @db.Timestamp(0)

  @@index([user_id, created_at], map: "idx_actlog_user")
}

model audit_log {
  id         String   @id @db.VarChar(36)
  actor_id   Int?
  action     String   @db.VarChar(100)
  target     String   @db.VarChar(200)
  before     Json?
  after      Json?
  ip_address String?  @db.VarChar(45)
  user_agent String?  @db.VarChar(500)
  created_at DateTime @default(now()) @db.Timestamp(0)

  @@index([actor_id], map: "idx_audit_actor")
  @@index([created_at], map: "idx_audit_created")
}

model conversation {
  id              String    @id @db.VarChar(36)
  student_id      Int
  mentor_id       Int
  last_message_at DateTime? @db.Timestamp(0)
  created_at      DateTime  @default(now()) @db.Timestamp(0)
  message         message[]

  @@unique([student_id, mentor_id], map: "uq_conv_pair")
  @@index([mentor_id], map: "idx_conv_mentor")
  @@index([student_id], map: "idx_conv_student")
}

model message {
  id              String       @id @db.VarChar(36)
  conversation_id String       @db.VarChar(36)
  sender_id       Int
  content         String       @db.Text
  read_at         DateTime?    @db.Timestamp(0)
  created_at      DateTime     @default(now()) @db.Timestamp(0)
  conversation    conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade, map: "fk_msg_conv")

  @@index([conversation_id, created_at], map: "idx_msg_conv")
}

model notification {
  id         String    @id @db.VarChar(36)
  user_id    Int
  type       String    @db.VarChar(50)
  title      String    @db.VarChar(200)
  body       String    @db.Text
  data       Json?
  read_at    DateTime? @db.Timestamp(0)
  created_at DateTime  @default(now()) @db.Timestamp(0)

  @@index([user_id, read_at], map: "idx_notif_user")
}

model notification_preference {
  id      String  @id @db.VarChar(36)
  user_id Int     @unique(map: "uq_notpref_user")
  email   Boolean @default(true)
  push    Boolean @default(true)
  in_app  Boolean @default(true)
}

model payout {
  id              String    @id @db.VarChar(36)
  mentor_id       Int
  amount          Decimal   @db.Decimal(10, 2)
  period_start    DateTime  @db.Timestamp(0)
  period_end      DateTime  @db.Timestamp(0)
  status          String    @default("pending") @db.VarChar(20)
  provider_ref_id String?   @db.VarChar(100)
  paid_at         DateTime? @db.Timestamp(0)
  created_at      DateTime  @default(now()) @db.Timestamp(0)

  @@index([mentor_id], map: "idx_payout_mentor")
  @@index([status], map: "idx_payout_status")
}

model session {
  id                  Int                        @id @default(autoincrement())
  student_id          Int
  mentor_id           Int
  title               String                     @db.VarChar(200)
  area                String                     @db.VarChar(100)
  scheduled_at        DateTime                   @db.Timestamp(0)
  duration_min        Int                        @default(60) @db.UnsignedSmallInt
  status              session_status             @default(scheduled)
  reservation_status  session_reservation_status @default(pending)
  video_platform      session_video_platform?
  meeting_link        String?                    @db.VarChar(512)
  joined_student_at   DateTime?                  @db.Timestamp(0)
  joined_mentor_at    DateTime?                  @db.Timestamp(0)
  cancelled_by        Int?
  cancellation_reason String?                    @db.VarChar(300)
  payment_status      session_payment_status     @default(unpaid)
  created_at          DateTime                   @default(now()) @db.Timestamp(0)
  feedback            feedback?
  payment             payment[]
  mentor              mentor                     @relation(fields: [mentor_id], references: [id], map: "fk_session_mentor")
  student             student                    @relation(fields: [student_id], references: [id], map: "fk_session_student")

  @@index([scheduled_at], map: "idx_session_date")
  @@index([mentor_id], map: "idx_session_mentor")
  @@index([reservation_status], map: "idx_session_reserve")
  @@index([status], map: "idx_session_status")
  @@index([student_id], map: "idx_session_student")
}

model user {
  id                         Int             @id @default(autoincrement())
  cpf                        String          @unique(map: "uq_user_cpf") @db.Char(11)
  name                       String          @db.VarChar(120)
  email                      String          @unique(map: "uq_user_email") @db.VarChar(255)
  phone                      String          @db.VarChar(20)
  password_hash              String          @db.VarChar(255)
  avatar_url                 String?         @db.VarChar(512)
  is_student                 Boolean         @default(true)
  is_mentor                  Boolean         @default(false)
  is_mentor_profile_complete Boolean         @default(false)
  is_admin                   Boolean         @default(false)
  email_verified             Boolean         @default(false)
  created_at                 DateTime        @default(now()) @db.Timestamp(0)
  updated_at                 DateTime        @default(now()) @db.Timestamp(0)
  address                    address[]
  mentor                     mentor?
  student                    student?
  user_language              user_language[]
}

model activity {
  id          Int           @id @default(autoincrement())
  student_id  Int
  title       String        @db.VarChar(200)
  details_url String?       @db.VarChar(512)
  type        activity_type @default(other)
  created_at  DateTime      @default(now()) @db.Timestamp(0)
  student     student       @relation(fields: [student_id], references: [id], onDelete: Cascade, map: "fk_act_student")

  @@index([created_at], map: "idx_act_date")
  @@index([student_id], map: "idx_act_student")
}

model address {
  id           Int     @id @default(autoincrement())
  user_id      Int
  postal_code  String  @db.Char(8)
  street       String  @db.VarChar(150)
  number       String  @db.VarChar(10)
  complement   String? @db.VarChar(80)
  neighborhood String  @db.VarChar(100)
  city         String  @db.VarChar(100)
  state        String  @db.Char(2)
  country      String  @default("Brasil") @db.VarChar(60)
  is_primary   Boolean @default(false)
  user         user    @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_address_user")

  @@index([user_id], map: "idx_address_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model availability {
  id              Int      @id @default(autoincrement())
  mentor_id       Int
  day_of_week     Int      @db.UnsignedTinyInt
  start_time      DateTime @db.Time(0)
  end_time        DateTime @db.Time(0)
  active          Boolean  @default(true)
  video_platforms String?
  mentor          mentor   @relation(fields: [mentor_id], references: [id], onDelete: Cascade, map: "fk_avail_mentor")

  @@index([day_of_week], map: "idx_avail_day")
  @@index([mentor_id], map: "idx_avail_mentor")
}

model language {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(60)
  code            String            @unique(map: "uq_language_code") @db.Char(2)
  mentor_language mentor_language[]
  user_language   user_language[]
}

model mentor_language {
  mentor_id   Int
  language_id Int
  language    language @relation(fields: [language_id], references: [id], onDelete: Cascade, map: "fk_ml_lang")
  mentor      mentor   @relation(fields: [mentor_id], references: [id], onDelete: Cascade, map: "fk_ml_mentor")

  @@id([mentor_id, language_id])
  @@index([language_id], map: "fk_ml_lang")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model mentor_review {
  id         Int      @id @default(autoincrement())
  mentor_id  Int
  student_id Int
  rating     Decimal  @db.Decimal(2, 1)
  title      String?  @db.VarChar(120)
  comment    String?  @db.Text
  created_at DateTime @default(now()) @db.Timestamp(0)
  mentor     mentor   @relation(fields: [mentor_id], references: [id], onDelete: Cascade, map: "fk_review_mentor")
  student    student  @relation(fields: [student_id], references: [id], onDelete: Cascade, map: "fk_review_student")

  @@index([mentor_id], map: "idx_review_mentor")
  @@index([rating], map: "idx_review_rating")
  @@index([student_id], map: "idx_review_student")
}

model mentor_technology {
  mentor_id     Int
  technology_id Int
  mentor        mentor     @relation(fields: [mentor_id], references: [id], onDelete: Cascade, map: "fk_mt_mentor")
  technology    technology @relation(fields: [technology_id], references: [id], onDelete: Cascade, map: "fk_mt_technology")

  @@id([mentor_id, technology_id])
  @@index([technology_id], map: "fk_mt_technology")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model payment {
  id                  Int            @id @default(autoincrement())
  session_id          Int
  payer_user_id       Int
  amount              Decimal        @db.Decimal(10, 2)
  method              payment_method @default(pix)
  status              payment_status @default(pending)
  provider            String?        @default("mercadopago") @db.VarChar(30)
  provider_payment_id String?        @db.VarChar(100)
  pix_qr_code         String?        @db.Text
  pix_ticket_url      String?        @db.VarChar(512)
  paid_at             DateTime?      @db.Timestamp(0)
  refunded_at         DateTime?      @db.Timestamp(0)
  created_at          DateTime       @default(now()) @db.Timestamp(0)
  session             session        @relation(fields: [session_id], references: [id], map: "fk_payment_session")

  @@index([payer_user_id], map: "idx_payment_payer")
  @@index([session_id], map: "idx_payment_session")
  @@index([status], map: "idx_payment_status")
}

model skill {
  id             Int              @id @default(autoincrement())
  name           String           @unique(map: "uq_skill_name") @db.VarChar(80)
  skill_progress skill_progress[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model skill_progress {
  id          Int      @id @default(autoincrement())
  student_id  Int
  skill_id    Int
  level       Int      @default(0) @db.UnsignedTinyInt
  recorded_at DateTime @default(now()) @db.Timestamp(0)
  skill       skill    @relation(fields: [skill_id], references: [id], onDelete: Cascade, map: "fk_sp_skill")
  student     student  @relation(fields: [student_id], references: [id], onDelete: Cascade, map: "fk_sp_student")

  @@index([recorded_at], map: "idx_sp_date")
  @@index([skill_id], map: "idx_sp_skill")
  @@index([student_id], map: "idx_sp_student")
}

model student {
  id                  Int              @id @default(autoincrement())
  user_id             Int              @unique(map: "uq_student_user")
  academic_background String?          @db.VarChar(120)
  activity            activity[]
  mentor_review       mentor_review[]
  session             session[]
  skill_progress      skill_progress[]
  user                user             @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_student_user")
}

model technology {
  id                Int                 @id @default(autoincrement())
  name              String              @unique(map: "uq_technology_name") @db.VarChar(80)
  category          technology_category @default(tech)
  mentor_technology mentor_technology[]
}

model user_language {
  user_id     Int
  language_id Int
  language    language @relation(fields: [language_id], references: [id], onDelete: Cascade, map: "fk_ul_lang")
  user        user     @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_ul_user")

  @@id([user_id, language_id])
  @@index([language_id], map: "fk_ul_lang")
}

enum technology_category {
  tech
  tool
  law
  soft_skill
}

enum activity_type {
  feedback
  achievement
  integration
  challenge
  other
}

enum payment_method {
  pix
  credit_card
}

enum payment_status {
  pending
  approved
  rejected
  refunded
}

enum session_status {
  scheduled
  in_progress
  completed
  cancelled
}

enum session_reservation_status {
  pending
  approved
  rejected
}

enum session_video_platform {
  google_meet
  microsoft_teams
  zoom
  discord
}

enum session_payment_status {
  unpaid
  pending
  paid
  refunded
}
